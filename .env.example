# ─── General ──────────────────────────────────────────────
APP_ENV=development                      # development|test exposes /auth/dev-bootstrap-super-admin
LOG_LEVEL=INFO
API_KEY=change-me-admin-api-key          # legacy X-API-Key for /bookings, /calls

# Frontend build-time API base (browser -> host-published backend port).
NEXT_PUBLIC_API_BASE=http://localhost:8000/api/v1

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/callcenter
DATABASE_URL_SYNC=postgresql+psycopg://postgres:postgres@postgres:5432/callcenter

# ─── Redis / Celery ───────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Auth / JWT (admin dashboard) ─────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# ─── AI provider ──────────────────────────────────────────
# AI_PROVIDER=mock (default) works with no API key — used by tests/dev/CI.
# AI_PROVIDER=claude requires ANTHROPIC_API_KEY (fails fast otherwise).
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
AI_TIMEOUT_SECONDS=15
AI_MAX_TOKENS=1024
# AI_TEMPERATURE is optional; leave unset for the model default (recommended).
# AI_TEMPERATURE=0.2
LLM_INTENT_MODEL=claude-haiku-4-5

# ─── RAG / embeddings (optional in MVP — keyword search works without it) ──
EMBEDDING_PROVIDER=azure
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=1536

# ─── Voice layer (STT/TTS) — mock only for now ────────────
# Default mock providers need no keys and never call external services.
# Real providers (whisper/deepgram/yandex, openai/elevenlabs/yandex) are wired later.
STT_PROVIDER=mock        # mock | openai_whisper (opt-in)
TTS_PROVIDER=mock        # mock | openai_tts (opt-in)
STT_TIMEOUT_SECONDS=15
TTS_TIMEOUT_SECONDS=15
DEFAULT_VOICE_UZ=uz-UZ-MadinaNeural
DEFAULT_VOICE_RU=ru-RU-SvetlanaNeural

# Real TTS (OpenAI TTS) — only used when TTS_PROVIDER=openai_tts.
# Install the extra first: pip install -e ".[tts]"  (reuses OPENAI_API_KEY)
TTS_MODEL=tts-1
TTS_VOICE_UZ=alloy               # OpenAI voice name; empty -> DEFAULT_VOICE_UZ
TTS_VOICE_RU=nova                # OpenAI voice name; empty -> DEFAULT_VOICE_RU
TTS_AUDIO_FORMAT=mp3             # mp3 | wav | opus | aac | flac | pcm
TTS_MAX_TEXT_CHARS=4000          # over this -> safe operator transfer

# Real STT (OpenAI Whisper) — only used when STT_PROVIDER=openai_whisper.
# Install the extra first: pip install -e ".[stt]"
OPENAI_API_KEY=
STT_MODEL=whisper-1
STT_LANGUAGE_HINT=               # optional ISO-639-1, e.g. uz or ru
STT_MAX_AUDIO_BYTES=25000000     # 25 MB
# STT_ALLOWED_CONTENT_TYPES=audio/wav,audio/mpeg,audio/mp4,audio/webm,audio/ogg,application/octet-stream

# Audio storage (metadata in DB, blobs OUT of DB). memory|local now; s3 later.
AUDIO_STORAGE_PROVIDER=memory
AUDIO_STORAGE_PATH=./data/audio
AUDIO_RETENTION_DAYS=90
SIGNED_URL_TTL_SECONDS=300
# Real object storage placeholders (no implementation yet):
# S3_BUCKET=
# S3_REGION=
# S3_ENDPOINT_URL=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# ─── Telephony intake (spike) — mock default; twilio is a skeleton only ────
# Mock webhook needs no account. If TELEPHONY_WEBHOOK_SECRET is set, the mock
# webhook requires header X-Telephony-Secret to match.
TELEPHONY_PROVIDER=mock          # mock | twilio
TELEPHONY_WEBHOOK_SECRET=        # optional shared secret for the mock webhook
TELEPHONY_MAX_PAYLOAD_BYTES=1000000   # 1 MB; oversized webhook body -> HTTP 422

# Twilio Voice webhook (non-streaming Gather/SpeechResult; NOT Media Streams).
# twilio mode requires TWILIO_AUTH_TOKEN (below) and fails fast without it.
TWILIO_VALIDATE_SIGNATURE=true   # verify X-Twilio-Signature (needs PUBLIC_BASE_URL)
TWILIO_VOICE=alice               # Twilio <Say> voice
TWILIO_GATHER_LANGUAGE=ru-RU     # Twilio <Gather>/<Say> language locale
TWILIO_GATHER_TIMEOUT_SECONDS=5
# PUBLIC_BASE_URL must be your public https URL (e.g. ngrok) so the signed URL
# Twilio sends matches what the server reconstructs. See below.

# Twilio Media Streams (WebSocket spike) — parser/lifecycle only, no streaming AI.
# When true, /twilio/voice returns <Connect><Stream> to TWILIO_STREAM_URL instead
# of the Gather/SpeechResult flow.
TWILIO_USE_MEDIA_STREAMS=false
TWILIO_STREAM_URL=               # wss://<public-host>/api/v1/telephony/twilio/media-stream
TWILIO_STREAM_MAX_FRAME_BYTES=8000        # cap counted bytes per media frame
TWILIO_STREAM_MAX_FRAMES_PER_CALL=50000   # cap frames processed per stream

# Streaming STT (mock-first) — only runs when media streams AND this are enabled.
# Mock only: no real recognition, no AI/TTS. See docs/streaming-stt.md.
STREAMING_STT_PROVIDER=mock               # mock | deepgram (deepgram is opt-in, real)
STREAMING_STT_ENABLED=false
STREAMING_STT_MAX_FRAMES=10000            # per-stream frame cap (then close safely)
STREAMING_STT_MAX_BYTES=8000000           # per-stream byte cap
STREAMING_STT_FINAL_AFTER_FRAMES=25       # mock: emit final after N frames
# Real streaming STT (Deepgram) - only used when STREAMING_STT_PROVIDER=deepgram.
# Tests never call Deepgram (a fake connection is injected). Key is never logged.
DEEPGRAM_API_KEY=                          # required when provider=deepgram (fail fast if empty)
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=                         # optional (e.g. ru, multi); empty -> provider default
DEEPGRAM_ENCODING=mulaw                    # matches Twilio media (8k mu-law)
DEEPGRAM_SAMPLE_RATE=8000
DEEPGRAM_INTERIM_RESULTS=true              # drive barge-in from interim transcripts
DEEPGRAM_ENDPOINTING=                      # optional (false or ms, e.g. 300)
DEEPGRAM_CONNECT_TIMEOUT_SECONDS=5.0
DEEPGRAM_RECEIVE_TIMEOUT_SECONDS=0.05
DEEPGRAM_MAX_MESSAGE_BYTES=1000000
DEEPGRAM_MAX_TRANSCRIPT_CHARS=2000
# Streaming AI turns: a FINAL transcript runs through the full AI/safety pipeline
# (text turn only; NO streaming TTS / no audio sent back yet).
STREAMING_STT_AI_TURNS_ENABLED=true       # final transcript -> one AI text turn
STREAMING_STT_MAX_TURNS=50                # cap AI turns per stream (bounds metadata)
STREAMING_STT_MAX_TRANSCRIPT_CHARS=2000   # cap transcript chars per turn
# Streaming TTS playback (mock-first): synthesize the AI turn reply and stream it
# back as Twilio media + mark events. No barge-in, no real provider yet.
STREAMING_TTS_ENABLED=false               # default off -> AI turn persisted, no outbound media
STREAMING_TTS_PROVIDER=mock               # mock | deepgram (deepgram is opt-in, real)
STREAMING_TTS_CHUNK_BYTES=400             # outbound audio bytes per media frame (pre-base64)
STREAMING_TTS_MAX_TEXT_CHARS=2000         # cap reply chars synthesized per turn
STREAMING_TTS_MAX_CHUNKS_PER_TURN=200     # cap media frames per turn (bounds output)
STREAMING_TTS_VOICE_UZ=uz-UZ-MadinaNeural
STREAMING_TTS_VOICE_RU=ru-RU-SvetlanaNeural
# Real streaming TTS (Deepgram) - only used when STREAMING_TTS_PROVIDER=deepgram.
# Reuses DEEPGRAM_API_KEY. Tests never call Deepgram (a fake connection is injected).
# Key is never logged. encoding/sample_rate/container default to RAW 8k mu-law so
# Twilio Media Streams can play the frames directly (no WAV/container header).
DEEPGRAM_TTS_MODEL=aura-asteria-en         # Deepgram TTS voice/model id
DEEPGRAM_TTS_ENCODING=mulaw                # matches Twilio media (8k mu-law)
DEEPGRAM_TTS_SAMPLE_RATE=8000
DEEPGRAM_TTS_CONTAINER=none                # RAW frames, no WAV/RIFF header
DEEPGRAM_TTS_SPEED=                         # optional (e.g. 1.1); empty -> provider default
DEEPGRAM_TTS_CONNECT_TIMEOUT_SECONDS=5.0
DEEPGRAM_TTS_RECEIVE_TIMEOUT_SECONDS=5.0   # wait for synthesized audio
DEEPGRAM_TTS_MAX_MESSAGE_BYTES=1000000
# Barge-in (mock-first): caller speech during playback sends a Twilio clear event.
BARGE_IN_ENABLED=false                     # default off -> keep A26 playback behavior
BARGE_IN_ON_PARTIAL=true                   # a partial transcript triggers barge-in
BARGE_IN_ON_FINAL=true                     # a final transcript triggers barge-in
BARGE_IN_MIN_TRANSCRIPT_CHARS=1            # ignore shorter (noise) transcripts
# Streaming latency metrics (instrumentation only): numeric ms offsets/durations
# in stream_metadata.latency. No audio/payloads.
STREAMING_METRICS_ENABLED=true            # record latency metrics (numbers only)
STREAMING_METRICS_INCLUDE_TIMESTAMPS=false # add wall-clock ISO times (default off)

# ─── POST-MVP: real telephony / STT-TTS (not used until simulation works) ──
PUBLIC_BASE_URL=http://localhost:8000
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

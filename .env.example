# AZURE_TTS_VOICE_RU=ru-RU-SvetlanaNeural
# STT_DEFAULT_LANGUAGES=uz-UZ,ru-RU
# Real STT/TTS placeholders (no implementation yet):
# OPENAI_API_KEY=
# DEEPGRAM_API_KEY=
# ELEVENLABS_API_KEY=
# YANDEX_SPEECHKIT_API_KEY=
